# 2. Permanent SQLite Local Database Initialisation

DB_FILE = "450canada.db"


def get_db_connection():

    conn = sqlite3.connect(DB_FILE)

    conn.row_factory = sqlite3.Row

    return conn


def init_db():

    conn = get_db_connection()

    cursor = conn.cursor()

    

    # Create Users Matrix Table

    cursor.execute("""

        CREATE TABLE IF NOT EXISTS users (

            email TEXT PRIMARY KEY,

            password TEXT,

            role TEXT,

            name TEXT,

            paid INTEGER

        )

    """)

    

    # Create Permanent Bowlers Database Matrix Table

    cursor.execute("""

        CREATE TABLE IF NOT EXISTS bowlers (

            name TEXT PRIMARY KEY,

            bowling_centre TEXT,

            tour_region TEXT,

            province TEXT,

            zone TEXT,

            division TEXT,

            total_pins INTEGER,

            games INTEGER,

            high_single INTEGER,

            high_triple INTEGER,

            accolades TEXT

        )

    """)

    

    # Insert Core Structural Mock Seed Data if the database files are brand new

    cursor.execute("SELECT COUNT(*) FROM users")

    if cursor.fetchone()[0] == 0:

        cursor.executemany("INSERT INTO users VALUES (?, ?, ?, ?, ?)", [

            ("admin@oshawalanes.ca", "password123", "Bowling Centre", "NEB's Fun World", 1),

            ("secretary@adultleague.com", "password456", "League Host", "Durham Region Adult League", 0),

