            ("emma@5pinbowler.ca", "emma", "Individual Bowler", "Emma Wong", 0)

        ])

        

    cursor.execute("SELECT COUNT(*) FROM bowlers")

    if cursor.fetchone()[0] == 0:

        cursor.executemany("INSERT INTO bowlers VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)", [

            ("Mitch Davies", "Calgary Lanes (Calgary, AB)", "Western Canada Tour", "Alberta", "Zone 2 (Calgary)", "Master Bowlers (Tournament)", 7560, 30, 385, 910, "🥇 350+ Club, 🏆 900+ Series"),

            ("Emma Wong", "NEB's Fun World (Oshawa, ON)", "Central Canada Tour", "Ontario", "Zone D (Niagara)", "Master Bowlers (Tournament)", 7740, 30, 415, 945, "🔥 400+ Elite, 🏆 900+ Series"),

            ("Sarah Tremblay", "Laurentian Lanes (Montreal, QC)", "Central Canada Tour", "Quebec", "Zone 4 (Montreal)", "Adult Women's Open", 6120, 30, 310, 785, "🥈 300+ Club"),

