        # Extract data out from the SQL Local File

        df_bowlers = pd.read_sql_query("SELECT * FROM bowlers", conn)

        

        # Calculate Averages Dynamically on live values

        df_bowlers["Average"] = (df_bowlers["total_pins"] / df_bowlers["games"]).round(1)

        

        # Apply Filters safely onto DataFrame

        if selected_div != "All Divisions":

            df_bowlers = df_bowlers[df_bowlers["division"] == selected_div]

        if selected_tour != "All Regions":

            df_bowlers = df_bowlers[df_bowlers["tour_region"] == selected_tour]

        if search_alley:

            df_bowlers = df_bowlers[df_bowlers["bowling_centre"].str.contains(search_alley, case=False, na=False)]

            

        df_bowlers = df_bowlers.sort_values(by="Average", ascending=False).reset_index(drop=True)

        df_bowlers.index += 1  

        

        if df_bowlers.empty:

            st.warning("No data matrices found matching this criteria.")

        else:

            ui_df = df_bowlers.rename(columns={

